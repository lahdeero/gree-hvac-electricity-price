{
  "compilerOptions": {
    "strict": true,
    "target": "ES2016",
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["ES2016"],
    "typeRoots": [
      "./node_modules/@types",
      "src/types"
    ]
  },
  "include": ["src", "types"],
  "exclude": ["dist", "node_modules"]
}
