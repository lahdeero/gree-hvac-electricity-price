{
  "compilerOptions": {
    "strict": true,
    "target": "es5",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "lib": [
      "dom",
      "es2015"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "src/types"
    ]
  },
  "include": ["src", "types"],
  "exclude": ["dist", "node_modules"]
}
