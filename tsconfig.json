{
  "compilerOptions": {
    "strict": true,
    "target": "ES2016",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
